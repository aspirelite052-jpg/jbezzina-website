# ─── Site URL ───
NEXT_PUBLIC_SITE_URL=http://jbezzina.store

# ─── Enquiry email (configure ONE method) ───

# Option A: Resend (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# ENQUIRY_FROM=enquiries@your-verified-domain.com
# ENQUIRY_TO=jason@jbezzina.com,clayton@jbezzina.com

# Option B: SMTP (Office 365, Gmail app password, cPanel, etc.)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=enquiries@jbezzina.com
# ENQUIRY_TO=jason@jbezzina.com,clayton@jbezzina.com

# Option C: Webhook (Zapier, Make, custom CRM)
# ENQUIRY_WEBHOOK_URL=https://hooks.example.com/enquiry

# In development with no email config, enquiries are logged to the terminal.
